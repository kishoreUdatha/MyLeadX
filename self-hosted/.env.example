# ============================================
# VoiceBridge Self-Hosted Configuration
# ============================================

# LICENSE (Required)
LICENSE_KEY=XXXX-XXXX-XXXX-XXXX-XXXX
LICENSE_SERVER_URL=https://license.voicebridge.com

# INSTANCE (Required)
APP_DOMAIN=crm.yourcompany.com
APP_NAME=Your Company CRM
COMPOSE_PROJECT_NAME=voicebridge
VERSION=latest

# ADMIN (Required)
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=ChangeMe123!

# DATABASE (Required)
DB_USER=voicebridge
DB_PASSWORD=your-secure-database-password
DB_NAME=voicebridge

# SECURITY (Required)
JWT_SECRET=your-jwt-secret-min-32-characters
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters
CREDENTIALS_ENCRYPTION_KEY=your-encryption-key-32-chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# EMAIL (Recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourcompany.com

# TELEPHONY (Choose one)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=

# AI (Required for Voice AI)
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# STORAGE (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1

# PAYMENT (Optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# TRAEFIK
TRAEFIK_LOG_LEVEL=INFO

# TIMEZONE
TZ=UTC
