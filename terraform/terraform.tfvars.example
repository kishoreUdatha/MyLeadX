# MyLeadX - Terraform Variables
# Copy this file to terraform.tfvars and fill in your values

# AWS Region (default: ap-south-1 Mumbai)
aws_region = "ap-south-1"

# Project Name
project_name = "myleadx"

# Domain Name
domain_name = "myleadx.ai"

# EC2 Instance Type
# t3.micro  = 1 vCPU, 1GB RAM  (~$8/month)  - Testing only
# t3.small  = 2 vCPU, 2GB RAM  (~$15/month) - Light usage
# t3.medium = 2 vCPU, 4GB RAM  (~$30/month) - Recommended
# t3.large  = 2 vCPU, 8GB RAM  (~$60/month) - Heavy usage
instance_type = "t3.medium"

# SSH Public Key
# Generate with: ssh-keygen -t rsa -b 4096 -f myleadx-key
# Then copy contents of myleadx-key.pub here
ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAACAQ..."

# GitHub Repository
github_repo = "https://github.com/kishoreUdatha/VoiceBridge.git"
