# =============================================================================
# CRM LEAD GENERATION - DOCKER COMPOSE ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your credentials
# NEVER commit .env file to version control
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-postgres-password
POSTGRES_DB=crm_lead_generation
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Generate secure secrets: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-characters
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Base URL for webhooks (use ngrok URL for local development)
BASE_URL=https://your-ngrok-subdomain.ngrok-free.dev

# CORS Origins (comma-separated for multiple origins in production)
# Example: https://example.com,https://www.example.com
CORS_ORIGINS=

# =============================================================================
# TWILIO - SMS, WhatsApp, Voice
# Get credentials: https://console.twilio.com/
# =============================================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# =============================================================================
# PLIVO - SMS, Voice (Alternative provider)
# Get credentials: https://console.plivo.com/
# =============================================================================
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_PHONE_NUMBER=

# =============================================================================
# EXOTEL - India Calling (Alternative provider for India)
# Get credentials: https://my.exotel.com/
# =============================================================================
EXOTEL_ACCOUNT_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_CALLER_ID=
EXOTEL_SUBDOMAIN=api.exotel.com

# Exotel SMS DLT Configuration (Required for India SMS)
# Register on DLT portal (Jio/Airtel/Vodafone) first
# Then link templates in Exotel dashboard
EXOTEL_SMS_SENDER_ID=SMTGRW
EXOTEL_DLT_ENTITY_ID=1234567890123456789
EXOTEL_DLT_TEMPLATE_ID=1234567890123456789

# Provider Selection: 'twilio', 'plivo', or 'exotel'
SMS_PROVIDER=twilio
VOICE_PROVIDER=twilio

# =============================================================================
# OPENAI - AI Voice Agents, Chatbot
# Get API key: https://platform.openai.com/api-keys
# =============================================================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# RAZORPAY - Payment Processing
# Get credentials: https://dashboard.razorpay.com/
# =============================================================================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# EMAIL - SMTP Configuration
# Gmail: Enable 2FA, create App Password at https://myaccount.google.com/apppasswords
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=noreply@yourcompany.com

# =============================================================================
# FACEBOOK ADS
# Create app: https://developers.facebook.com/apps/
# =============================================================================
FACEBOOK_APP_ID=123456789012345
FACEBOOK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FACEBOOK_VERIFY_TOKEN=your-webhook-verify-token

# =============================================================================
# LINKEDIN ADS
# Create app: https://www.linkedin.com/developers/apps/
# =============================================================================
LINKEDIN_CLIENT_ID=xxxxxxxxxxxx
LINKEDIN_CLIENT_SECRET=xxxxxxxxxxxxxxxx

# =============================================================================
# GOOGLE ADS
# Get credentials: https://console.cloud.google.com/
# Developer token: https://ads.google.com/aw/apicenter
# =============================================================================
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# =============================================================================
# AWS S3 - File Storage (Optional)
# Get credentials: https://console.aws.amazon.com/iam/
# =============================================================================
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_BUCKET_NAME=your-bucket-name
AWS_REGION=ap-south-1

# =============================================================================
# FRONTEND
# =============================================================================
VITE_API_URL=http://localhost:3000/api

